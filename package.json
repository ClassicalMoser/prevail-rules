{
  "name": "@classicalmoser/prevail-rules",
  "version": "0.0.1",
  "description": "Rules for the web-based board game Prevail: Ancient Battles",
  "keywords": [
    "ancient-battles",
    "board-game",
    "prevail",
    "rules",
    "typescript"
  ],
  "license": "ISC",
  "author": "ClassicalMoser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClassicalMoser/prevail-rules.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js"
    },
    "./application": {
      "types": "./dist/application/index.d.ts",
      "import": "./dist/application/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "validate": "npm run lint && npm run format && npm run typecheck",
    "version:patch": "tsx scripts/version-bump.ts patch",
    "version:minor": "tsx scripts/version-bump.ts minor"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.17",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-boundaries": "^0.8.1",
    "eslint-plugin-node": "^11.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsdown": "0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  },
  "volta": {
    "node": "20.20.0",
    "pnpm": "9.7.0"
  },
  "packageManager": "pnpm@10.33.2"
}
